            { "key": "file", "type": "file", "src": "" }
          ]
        },
        "url": {
          "raw": "http://localhost:8000/ingest?storage_mode=local",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["ingest"],
